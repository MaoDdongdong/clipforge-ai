# Database
DATABASE_URL="postgresql://user:password@localhost:5432/clipforge"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# AI Provider (mock or openai-compatible)
AI_PROVIDER="mock"

# OpenAI-Compatible Provider (only needed if AI_PROVIDER=openai-compatible)
OPENAI_COMPATIBLE_API_KEY=""
OPENAI_COMPATIBLE_BASE_URL=""
OPENAI_COMPATIBLE_MODEL=""

# App Configuration
APP_DEFAULT_LOCALE="en-US"
APP_SUPPORTED_LOCALES="en-US,zh-CN"